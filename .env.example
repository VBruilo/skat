# Firebase Web-Config (aus der Firebase Console -> Projekteinstellungen -> Deine Apps -> Web-App).
# Diese Werte sind KEINE Geheimnisse (sie landen ohnehin im ausgelieferten Client-Bundle).
# Der Schutz kommt über die Firestore Security Rules + die Authorized Domains.
# Zum lokalen Entwickeln: diese Datei nach `.env.local` kopieren und ausfüllen.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
